# Application
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV=production

# Supabase (required by env validation, set real values for auth features)
NEXT_PUBLIC_SUPABASE_URL="https://example.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="dev-anon-key"
SUPABASE_SERVICE_ROLE_KEY="dev-service-role-key"

# PayOS (required by env validation, set real values for payment features)
PAYOS_CLIENT_ID="dev-client-id"
PAYOS_API_KEY="dev-api-key"
PAYOS_CHECKSUM_KEY="dev-checksum-key"

# Database
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/carbon_credit_app?schema=public"
DIRECT_URL="postgresql://postgres:postgres@postgres:5432/carbon_credit_app?schema=public"

# Docker service addresses
IMMUDB_HOST="immudb"
IMMUDB_PORT=3322
IMMUDB_USERNAME="immudb"
IMMUDB_PASSWORD="immudb"
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password123"
