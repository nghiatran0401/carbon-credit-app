# Application
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV=development

# Database (Supabase PostgreSQL)
# ?pgbouncer=true is required on the pooler URL (port 6543) to disable prepared statements
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# Docker local alternative:
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/carbon_credit_app?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@postgres:5432/carbon_credit_app?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# PayOS
PAYOS_CLIENT_ID="your-payos-client-id"
PAYOS_API_KEY="your-payos-api-key"
PAYOS_CHECKSUM_KEY="your-payos-checksum-key"

# ImmuDB (optional — enables immutable audit ledger)
# IMMUDB_HOST="immudb" # use "localhost" outside Docker
# IMMUDB_PORT=3322
# IMMUDB_USERNAME="immudb"
# IMMUDB_PASSWORD="immudb"

# Neo4j (optional — enables graph-based carbon movement tracking)
# NEO4J_URI="bolt://neo4j:7687" # use "bolt://localhost:7687" outside Docker
# NEO4J_USER="neo4j"
# NEO4J_PASSWORD="password"

# Base L2 Blockchain (optional — anchors audit Merkle roots on Base)
# BASE_RPC_URL="https://sepolia.base.org"
# BASE_CHAIN_ID=84532
# ANCHOR_PRIVATE_KEY="your-wallet-private-key"
# ANCHOR_CONTRACT_ADDRESS="deployed-contract-address"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"

# Biomass Analysis API (required for /biomass-only page)
NEXT_PUBLIC_BIOMASS_API_URL="https://your-biomass-api-url.example.com"
